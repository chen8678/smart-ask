  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 100%;
  padding: 0 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.header-title h2 {
  margin: 0;
  color: #2c3e50;
  font-size: 1.5rem;
  font-weight: 600;
}

.header-title p {
  margin: 0;
  color: #6c757d;
  font-size: 0.9rem;
}

.header-controls {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.control-group {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.control-group label {
  font-size: 0.8rem;
  color: #6c757d;
  font-weight: 500;
}

.control-select {
  min-width: 160px;
}
  padding: 0 20px;
}

.header-left {
  display: flex;
  align-items: center;
}

.header-content h2 {
  color: #2c3e50;
  margin: 0;
}

.header-actions {
  display: flex;
  align-items: center;
}

.chat-main {
  flex: 1;
  padding: 0;
  overflow: hidden;
}

.chat-messages {
  height: 100%;
  overflow-y: auto;
  padding: 20px;
}

.message {
  display: flex;
  margin-bottom: 20px;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #409EFF;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 12px;
  flex-shrink: 0;
}

.message.user .message-avatar {
  background: #67C23A;
}

.message-content {
  max-width: 70%;
  background: white;
  padding: 12px 16px;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.message.user .message-content {
  background: #409EFF;
  color: white;
}

.message-text {
  margin-bottom: 8px;
  line-height: 1.5;
}

.message-time {
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
}

.message.user .message-time {
  color: rgba(255, 255, 255, 0.8);
}

.message-sources {
  margin-top: 8px;
}

.chat-footer {
  background: white;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
  padding: 20px;
}

.input-container {
  max-width: 800px;
  margin: 0 auto;
}

/* 会话列表样式 */
.session-list {
  max-height: 400px;
  overflow-y: auto;
}

.session-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border: 1px solid #e4e7ed;
  border-radius: 8px;
  margin-bottom: 12px;
  cursor: pointer;
  transition: all 0.3s;
}

.session-item:hover {
  border-color: #409eff;
  background-color: #f0f9ff;
}

.session-item.active {
  border-color: #409eff;
