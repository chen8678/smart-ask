  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400px;
}

.session-actions {
  display: flex;
  gap: 8px;
}

.empty-sessions {
  text-align: center;
  padding: 40px 0;
}

/* AI模型选择器样式 */
.model-unavailable {
  color: #c0c4cc;
}
</style>
